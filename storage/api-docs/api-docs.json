    "components": {
        "schemas": {
            "CamisetaInput": {
                "required": [
                    "titulo",
                    "club",
                    "pais",
                    "tipo",
                    "color",
                    "precio",
                    "codigo_producto"
                ],
                "properties": {
                    "titulo": {
                        "type": "string",
                        "example": "Camiseta Local 2025 – Selección Chilena"
                    },
                    "club": {
                        "type": "string",
                        "example": "Selección Chilena"
                    },
                    "pais": {
                        "type": "string",
                        "example": "Chile"
                    },
                    "tipo": {
                        "type": "string",
                        "example": "Local"
                    },
                    "color": {
                        "type": "string",
                        "example": "Rojo"
                    },
                    "precio": {
                        "type": "integer",
                        "example": 45000
                    },
                    "precio_oferta": {
                        "type": "integer",
                        "example": 38000,
                        "nullable": true
                    },
                    "detalles": {
                        "type": "string",
                        "example": "Edición aniversario 2025",
                        "nullable": true
                    },
                    "codigo_producto": {
                        "type": "string",
                        "example": "SCL2025L"
                    },
                    "cliente_id": {
                        "type": "integer",
                        "example": 1,
                        "nullable": true
                    },
                    "tallas": {
                        "type": "array",
