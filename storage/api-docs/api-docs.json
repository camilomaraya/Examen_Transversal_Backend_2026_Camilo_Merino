                    },
                    "precio": {
                        "type": "integer",
                        "example": 45000
                    },
                    "precio_oferta": {
                        "type": "integer",
                        "example": 38000,
                        "nullable": true
                    },
                    "detalles": {
                        "type": "string",
                        "example": "Edición aniversario 2025",
                        "nullable": true
                    },
                    "codigo_producto": {
                        "type": "string",
                        "example": "SCL2025L"
                    },
                    "cliente_id": {
                        "type": "integer",
                        "example": 1,
                        "nullable": true
                    },
                    "precio_final": {
                        "type": "integer",
                        "example": 38000
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "ClienteInput": {
                "required": [
                    "nombre_comercial",
                    "rut",
                    "direccion",
                    "tipo",
                    "contacto_nombre",
                    "contacto_email"
                ],
                "properties": {
                    "nombre_comercial": {
                        "type": "string",
                        "example": "90minutos"
                    },
                    "rut": {
                        "type": "string",
                        "example": "76.111.222-3"
                    },
                    "direccion": {
                        "type": "string",
                        "example": "Providencia, Santiago"
                    },
                    "tipo": {
                        "type": "string",
